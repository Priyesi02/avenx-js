{
  "name": "avenx-core",
  "version": "0.4.3",
  "description": "A lightweight reactive framework with scoped CSS and custom components.",
  "main": "lib/compiler.js",
  "exports": {
    ".": {
      "types": "./lib/compiler.d.ts",
      "default": "./lib/compiler.js"
    },
    "./runtime": {
      "types": "./lib/core/index.d.ts",
      "default": "./lib/core/index.js"
    },
    "./core": {
      "types": "./lib/core/index.d.ts",
      "default": "./lib/core/index.js"
    }
  },
  "bin": {
    "avenx": "bin/avenx.js"
  },
  "files": [
    "bin/",
    "lib/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node test/run-tests.js",
    "test:unit": "node test/run-tests.js unit",
    "test:integration": "node test/run-tests.js integration",
    "test:system": "node test/run-tests.js system",
    "test:e2e": "node test/run-tests.js e2e",
    "test:coverage": "c8 --reporter=text --reporter=html npm test",
    "bench": "node benches/run.js",
    "bench:report": "node benches/run.js --json > bench-results/results.json",
    "docs": "jsdoc -c jsdoc.json"
  },
  "keywords": [
    "reactive",
    "framework",
    "compiler",
    "css-in-js",
    "scoped-css",
    "frontend",
    "javascript",
    "lightweight",
    "components",
    "cli",
    "web-development"
  ],
  "author": "Avenx Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avenx-js/avenx-js.git"
  },
  "bugs": {
    "url": "https://github.com/avenx-js/avenx-js/issues"
  },
  "homepage": "https://avenx-js.com/",
  "devDependencies": {
    "jsdoc": "^4.0.2",
    "c8": "^9.1.0"
  }
}
